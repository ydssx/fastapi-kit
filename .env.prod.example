# Copy to .env.prod and replace every "replace-with-..." value before deployment.
# This file contains examples only; never commit .env.prod.
ENVIRONMENT=prod
DOMAIN=app.example.com
ACME_EMAIL=ops@example.com
LOG_LEVEL=INFO
SCALE_API=1

# Bundled PostgreSQL (not published to the host)
POSTGRES_USER=fastapi_kit
POSTGRES_PASSWORD=replace-with-a-strong-database-password
POSTGRES_DB=fastapi_kit
DATABASE_URL=postgresql+asyncpg://fastapi_kit:replace-with-a-strong-database-password@postgres:5432/fastapi_kit

# Bundled Redis (password protected, AOF enabled, not published to the host)
REDIS_PASSWORD=replace-with-a-strong-redis-password
REDIS_URL=redis://:replace-with-a-strong-redis-password@redis:6379/0

# Public application and security
JWT_SECRET=replace-with-at-least-32-random-characters
CORS_ORIGINS=["https://app.example.com"]
APP_PUBLIC_URL=https://app.example.com

# Bundled MinIO credentials; OBJECT_STORAGE_PUBLIC_ENDPOINT must be browser reachable.
OBJECT_STORAGE_ENDPOINT=http://minio:9000
OBJECT_STORAGE_PUBLIC_ENDPOINT=https://media.example.com
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_BUCKET=creator-media
OBJECT_STORAGE_ACCESS_KEY=replace-with-a-strong-minio-access-key
OBJECT_STORAGE_SECRET_KEY=replace-with-a-strong-minio-secret-key

# Optional integrations
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
IMAGE_GENERATION_API_KEY=
IMAGE_GENERATION_BASE_URL=https://api.openai.com/v1
IMAGE_GENERATION_MODEL=gpt-image-2
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_SECRET=
LOKI_URL=
