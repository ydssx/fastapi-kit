# Entry point for zero-downtime API restarts (see scripts/rolling_update.sh).

# TLS: local self-signed certs in docker/certs/ (scripts/gen_dev_certs.sh).

# Admin SPA: build with `make admin-build`, served at https://localhost/admin/

:443 {

	tls /etc/caddy/certs/cert.pem /etc/caddy/certs/key.pem



	# Exact /admin (no slash) must not fall through to API reverse_proxy.
	@admin_exact path /admin
	redir @admin_exact /admin/ permanent

	handle_path /admin/* {
		root * /srv/admin
		uri strip_prefix /admin
		try_files {path} /index.html
		file_server
	}



	handle {

		reverse_proxy {

			dynamic a api 8000 {

				refresh 5s

			}

			health_uri /health

			health_interval 5s

			health_timeout 3s

			fail_duration 15s

			lb_policy round_robin

		}

	}

}



# Keep :8000 for compatibility; redirect to HTTPS on the default port.

:8000 {

	redir https://{host}{uri} permanent

}

