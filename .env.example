# Application
ENVIRONMENT=dev
LOG_LEVEL=INFO
# Docker Compose HTTPS: run `bash scripts/gen_dev_certs.sh` once (auto-run by start.sh) for local self-signed TLS on https://localhost
# Docker Compose: SCALE_API=2 enables zero-downtime rolling updates (see scripts/rolling_update.sh)
# TRUST_PROXY_HEADERS=true when the API is behind Caddy/reverse proxy (set in docker-compose for api)
# TRUST_PROXY_HEADERS=false
# LOG_FILE=logs/app.log
# LOG_FILE_MAX_BYTES=10485760
# LOG_FILE_BACKUP_COUNT=5
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8000","https://localhost"]

# Admin SPA (Vite dev server)
# ADMIN_FRONTEND_ORIGIN=http://localhost:5173

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fastapi_kit

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery Beat (scheduled tasks)
# CELERY_TIMEZONE=UTC
# CELERY_BEAT_HEARTBEAT_INTERVAL_SECONDS=300
# CELERY_BEAT_SCHEDULE_FILE=logs/celerybeat-schedule
# CELERY_INSPECT_TIMEOUT=4.0
# CELERY_INSPECT_OVERALL_TIMEOUT=12.0

# JWT
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate limiting
RATE_LIMIT_PER_MINUTE=100

# Admin dashboard (optional)
# ADMIN_AUDIT_EXPORT_MAX_ROWS=5000
# ADMIN_REPORTED_API_REPLICAS=1
# FLOWER_URL=http://localhost:5555

# Admin alerts (optional seed; persisted in DB after admin UI update)
# ALERT_WEBHOOK_URL=https://hooks.example.com/alert
# ALERT_WEBHOOK_SECRET=
# ALERT_DEDUPE_SECONDS=300
# ALERT_CHECK_INTERVAL_SECONDS=120
# ALERT_WORKER_ZERO_ENABLED=false

# Loki log query (enable with: docker compose --profile ops up -d loki promtail)
# LOKI_URL=http://loki:3100
