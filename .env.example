# Application
# Local `make up` uses this file via .env. Production uses .env.prod.example -> .env.prod
# with `make prod-config` / `make up-prod`; never reuse these development credentials.
ENVIRONMENT=dev
LOG_LEVEL=INFO
# Docker Compose HTTPS: run `bash scripts/gen_dev_certs.sh` once (auto-run by start.sh) for local self-signed TLS on https://localhost
# Docker Compose: SCALE_API=2 enables zero-downtime rolling updates (see scripts/rolling_update.sh)
# TRUST_PROXY_HEADERS=true when the API is behind Caddy/reverse proxy (set in docker-compose for api)
# TRUST_PROXY_HEADERS=false
# LOG_FILE=logs/app.log
# LOG_FILE_MAX_BYTES=10485760
# LOG_FILE_BACKUP_COUNT=5
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:5174","http://localhost:8000","https://localhost"]

# Admin SPA (Vite dev server)
# ADMIN_FRONTEND_ORIGIN=http://localhost:5173

# Creator SPA (Vite dev server :5174)
# CORS_ORIGINS 需包含 http://localhost:5174 若本机 creator-dev

# Creator AI (OpenAI-compatible)
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# Native JSON Output for structured Creator calls (N-choice / topics / outline).
# Set false only if the upstream rejects response_format=json_object.
# LLM_JSON_OUTPUT=true
# CREATOR_FREE_COMPLETED_PROJECTS_PER_MONTH=2
# CREATOR_FREE_AI_CALLS_PER_MONTH=50
# CREATOR_PRO_MULTIPLIER=10

# Creator media storage (local Docker Compose uses MinIO)
# Do not commit production object-storage credentials.
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
# Browser-facing URL for signed previews. Required in Docker when the API uses
# http://minio:9000 internally — browsers cannot resolve the "minio" hostname.
# OBJECT_STORAGE_PUBLIC_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_BUCKET=creator-media
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
# OBJECT_STORAGE_PRESIGN_TTL_SECONDS=900
# CREATOR_MEDIA_MAX_UPLOAD_BYTES=10485760
# CREATOR_MEDIA_MAX_WIDTH=8192
# CREATOR_MEDIA_MAX_HEIGHT=8192

# Creator image generation (OpenAI Images API)
# IMAGE_GENERATION_API_KEY=
# IMAGE_GENERATION_BASE_URL=https://api.openai.com/v1
# IMAGE_GENERATION_MODEL=gpt-image-2
# IMAGE_GENERATION_TIMEOUT_SECONDS=90
# IMAGE_GENERATION_MAX_PROMPT_CHARS=4000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fastapi_kit

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery Beat (scheduled tasks)
# CELERY_TIMEZONE=UTC
# CELERY_BEAT_HEARTBEAT_INTERVAL_SECONDS=300
# CELERY_BEAT_SCHEDULE_FILE=logs/celerybeat-schedule
# CELERY_INSPECT_TIMEOUT=4.0
# CELERY_INSPECT_OVERALL_TIMEOUT=12.0

# JWT
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Public app URL (password reset links, emails)
# APP_PUBLIC_URL=https://localhost

# SMTP (optional; required for C-end forgot-password email)
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@local.dev
# SMTP_USE_TLS=false
# PASSWORD_RESET_EXPIRE_MINUTES=60
# PASSWORD_RESET_RATE_LIMIT_PER_HOUR=5

# Rate limiting
RATE_LIMIT_PER_MINUTE=100

# Admin dashboard (optional)
# ADMIN_AUDIT_EXPORT_MAX_ROWS=5000
# ADMIN_REPORTED_API_REPLICAS=1
# FLOWER_URL=http://localhost:5555

# Admin alerts (optional seed; persisted in DB after admin UI update)
# ALERT_WEBHOOK_URL=https://hooks.example.com/alert
# ALERT_WEBHOOK_SECRET=
# ALERT_DEDUPE_SECONDS=300
# ALERT_CHECK_INTERVAL_SECONDS=120
# ALERT_WORKER_ZERO_ENABLED=false

# Loki log query (enable with: docker compose --profile ops up -d loki promtail)
# LOKI_URL=http://loki:3100
